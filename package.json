{
  "name": "mariounam-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Static portfolio for Mario Huarte Nolasco. Build pipeline solo necesario para compilar Tailwind a CSS estatico (en lugar del CDN). El sitio funciona sin esto.",
  "scripts": {
    "build:css":         "tailwindcss -c tailwind.config.js -i assets/css/tailwind-input.css -o assets/css/tailwind.css --minify",
    "build:css:studio":  "tailwindcss -c studio/tailwind.config.js -i studio/assets/css/tailwind-input.css -o studio/assets/css/tailwind.css --minify",
    "build:css:all":     "npm run build:css && npm run build:css:studio",
    "watch:css":         "tailwindcss -c tailwind.config.js -i assets/css/tailwind-input.css -o assets/css/tailwind.css --watch",
    "watch:css:studio":  "tailwindcss -c studio/tailwind.config.js -i studio/assets/css/tailwind-input.css -o studio/assets/css/tailwind.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
